// Roo_mue data model.
//
// LOCAL DEV: SQLite (zero setup, runs immediately).
// PRODUCTION: switch `provider` to "postgresql" and point DATABASE_URL at your
// Postgres/Supabase instance. The models below are written to be portable;
// enum-like fields use String so the same schema works on SQLite.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- Auth (NextAuth-compatible) -------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String? // null when the account is Google-OAuth only
  image         String?

  // Registration profile (Page 2, Step 2)
  firstName          String?
  lastName           String?
  nationalId         String? // 13-digit Thai national ID (store encrypted in prod)
  disabilityCardNo   String? // optional

  accounts            Account[]
  sessions            Session[]
  translationSessions TranslationSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- App data --------------------------------------------------------------

// One translation session = one sentence produced from sign language input.
model TranslationSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // "emergency" | "everyday"
  mode String

  // Free-form context tag, e.g. "hospital", "police", "everyday".
  contextTag String?

  // Final chosen sentence (after the user picks one of the candidates).
  sentence String

  // The candidate meanings the engine proposed, stored as JSON string.
  // Shape: [{ text: string, confidence: number }]
  candidatesJson String?

  // "camera" | "preset"
  source String @default("camera")

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
